# Database
DATABASE_URL=postgresql://qubilt:qubilt@localhost:5432/qubilt_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_DRIVER=local   # "local" | "s3"
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=           # MinIO endpoint if self-hosted

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@qubilt.com

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development

# MinIO (dev only)
MINIO_ROOT_USER=qubilt
MINIO_ROOT_PASSWORD=qubilt_dev

# Meilisearch (optional)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# LiveKit (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Marketplace
MARKETPLACE_URL=http://localhost:3002
MARKETPLACE_API_KEY=
