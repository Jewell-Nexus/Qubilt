{
  "name": "@qubilt/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "ts-node --watch src/main.ts",
    "build": "tsc",
    "db:migrate": "prisma migrate dev --schema=src/database/prisma/kernel.prisma",
    "db:generate": "prisma generate --schema=src/database/prisma/kernel.prisma",
    "db:seed": "ts-node src/database/prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.0",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
