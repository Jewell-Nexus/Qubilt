{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@qubilt/shared": ["../../packages/shared/src"],
      "@qubilt/shared/*": ["../../packages/shared/src/*"],
      "@qubilt/module-sdk": ["../../packages/module-sdk/src/index.ts"],
      "@qubilt/module-sdk/*": ["../../packages/module-sdk/src/*"],
      "@qubilt/pm-api": ["../../modules/pm/api/src/pm.module.ts"],
      "@qubilt/pm-api/*": ["../../modules/pm/api/src/*"],
      "@qubilt/wiki-api": ["../../modules/wiki/api/src/wiki.module.ts"],
      "@qubilt/wiki-api/*": ["../../modules/wiki/api/src/*"],
      "@qubilt/chat-api": ["../../modules/chat/api/src/chat.module.ts"],
      "@qubilt/chat-api/*": ["../../modules/chat/api/src/*"],
      "@kernel/*": ["./src/kernel/*"]
    }
  },
  "include": ["src/**/*", "../../modules/*/api/src/**/*", "../../packages/*/src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
